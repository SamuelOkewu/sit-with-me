

# APP_URL: The URL where this applet is hosted.
# Automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SANITY_PROJECT_ID: Your Sanity project ID
VITE_SANITY_PROJECT_ID="9cjzddfw"
# SANITY_DATASET: Your Sanity dataset (e.g., 'production')
VITE_SANITY_DATASET="production"
# SANITY_API_VERSION: The API version to use (e.g., '2023-01-01')
VITE_SANITY_API_VERSION="2023-01-01"